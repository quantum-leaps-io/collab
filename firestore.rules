rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Rooms: any authenticated user can create or read.
    // Only the creator (or a joining peer) can update.
    match /rooms/{roomId} {
      // Allow any signed-in user to create a room
      allow create: if request.auth != null;

      // Allow any signed-in user to read (to join via roomId link)
      allow read: if request.auth != null;

      // Allow update only for adding an 'answer' field
      allow update: if request.auth != null
        && request.resource.data.keys().hasOnly(['offer','answer','createdBy','createdAt']);

      // ICE candidates sub-collections: any authenticated user can read/write
      match /callerCandidates/{candidateId} {
        allow read, create: if request.auth != null;
      }
      match /calleeCandidates/{candidateId} {
        allow read, create: if request.auth != null;
      }
    }
  }
}
